# MailPilot AI — docker compose environment
# Copy to docker/.env and fill in actual secrets. Never commit docker/.env.

# Container images (pulled from GHCR — built by CI on push to main)
# Override IMAGE_TAG to pin a specific build, e.g. sha-abc1234 or main.
IMAGE_REGISTRY=ghcr.io/callmetechie
IMAGE_TAG=latest

# Host ports (only used by docker-compose.synology.yml — DSM Reverse Proxy
# forwards to these). Defaults are 18080/18081 because Synology's
# Web Station occupies 8080.
BACKEND_PORT=18080
ADMIN_PORT=18081

# App
APP_ENV=prod
APP_DEBUG=false
APP_BASE_URL=https://your-host.example.com

# Auth — generate via: openssl rand -hex 32
JWT_SECRET=replace-me-32-bytes-hex
JWT_ISSUER=mailpilot.ai
JWT_AUDIENCE=mailpilot-addin
ENCRYPT_KEY=replace-me-32-bytes-hex

# CORS — comma-separated list of allowed origins for the add-in
CORS_ALLOWED_ORIGINS=https://outlook.office.com,https://outlook.office365.com

# Database
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=mailpilot
DB_USER=mailpilot
DB_PASS=replace-me-strong-password
DB_ROOT_PASS=replace-me-strong-root-password

# Redis
REDIS_HOST=redis
REDIS_PORT=6379

# Claude API (provider = anthropic OR bedrock)
CLAUDE_PROVIDER=anthropic
CLAUDE_API_KEY=sk-ant-...

# AWS Bedrock (only when CLAUDE_PROVIDER=bedrock)
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-central-1

# Microsoft Graph (Azure App Registration)
MS_CLIENT_ID=
MS_CLIENT_SECRET=
MS_REDIRECT_URI=https://your-host.example.com/api/v1/auth/oauth/callback

# Admin UI — login + optional IP restriction
# Generate ADMIN_PASS_HASH inside any running backend container:
#   docker exec mailpilot-backend php -r 'echo password_hash("YOUR_PASSWORD", PASSWORD_BCRYPT) . PHP_EOL;'
ADMIN_USER=admin
ADMIN_PASS_HASH=replace-me-bcrypt-hash
ADMIN_IP_RESTRICT=false
ADMIN_ALLOWED_IPS=
