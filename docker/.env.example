# ─────────────────────────────────────────────────────────────────────────
#  MailPilot AI — Container Stack Environment
# ─────────────────────────────────────────────────────────────────────────
#
# 1) Copy to docker/.env (or /docker/mailpilot-ai/.env on the NAS)
# 2) Fill every "REPLACE-ME-…" value
# 3) Never commit the resulting .env file
#
# Field reference and DSM-specific notes: docs/SYNOLOGY-INSTALL.md
# ─────────────────────────────────────────────────────────────────────────


# ─── Container images ────────────────────────────────────────────────────
# CI publishes multi-arch images (amd64 + arm64) to GHCR on every push to
# main. Pin IMAGE_TAG=sha-<short> for reproducible deploys, or leave it on
# 'latest' for rolling updates.
IMAGE_REGISTRY=ghcr.io/callmetechie
IMAGE_TAG=latest


# ─── Host ports ──────────────────────────────────────────────────────────
# Used by docker-compose.synology.yml. DSM's Web Station occupies 8080,
# Synology Photos 8000, etc. — the 19080/19081 defaults usually stay free.
# Verify on the NAS with:  ss -tlnp | grep -E ':(19080|19081) '
BACKEND_PORT=19080
ADMIN_PORT=19081


# ─── Application ─────────────────────────────────────────────────────────
APP_ENV=prod
APP_DEBUG=false

# Public URL of the backend (Outlook Add-in + Microsoft Graph call this).
# Must match the Reverse-Proxy entry on DSM and the Azure redirect URI.
APP_BASE_URL=https://mailpilot.deine-domain.de


# ─── Auth / crypto ───────────────────────────────────────────────────────
# Generate fresh values with:  openssl rand -hex 32
# Both must be exactly 64 hex chars. Don't reuse across deployments.
JWT_SECRET=REPLACE-ME-64-HEX-CHARS
ENCRYPT_KEY=REPLACE-ME-64-HEX-CHARS

JWT_ISSUER=mailpilot.ai
JWT_AUDIENCE=mailpilot-addin

# Comma-separated origins allowed by the backend's CORS policy.
# Keep both Outlook origins so desktop and web clients both work.
CORS_ALLOWED_ORIGINS=https://outlook.office.com,https://outlook.office365.com


# ─── Database (MariaDB) ──────────────────────────────────────────────────
# Application user (used by backend, worker, admin).
DB_HOST=mariadb
DB_PORT=3306
DB_NAME=mailpilot
DB_USER=mailpilot
DB_PASS=REPLACE-ME-STRONG-DB-PASSWORD

# Root password — required. The backend's entrypoint-init.sh uses it to
# (a) create the application DB user with wildcard host grant, and
# (b) apply schema migrations on first start (idempotent on later starts).
DB_ROOT_PASS=REPLACE-ME-STRONG-ROOT-PASSWORD


# ─── Redis ───────────────────────────────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379


# ─── Claude API ──────────────────────────────────────────────────────────
# CLAUDE_PROVIDER:
#   anthropic — direct Anthropic API (default; needs CLAUDE_API_KEY)
#   bedrock   — AWS Bedrock (eu-central-1, Claude on Sovereign EU); needs
#               AWS_* below; CLAUDE_API_KEY is unused
CLAUDE_PROVIDER=anthropic
CLAUDE_API_KEY=sk-ant-...

# AWS Bedrock credentials (only when CLAUDE_PROVIDER=bedrock; leave blank
# otherwise — empty values are valid).
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_SESSION_TOKEN=
AWS_REGION=eu-central-1


# ─── Microsoft Graph (Azure App Registration) ────────────────────────────
# Get these from https://entra.microsoft.com → your app → Overview / Secrets.
# MS_REDIRECT_URI must equal exactly  ${APP_BASE_URL}/api/v1/auth/oauth/callback
# and must also be registered in Azure under "Authentication".
MS_CLIENT_ID=REPLACE-ME-AZURE-CLIENT-ID
MS_CLIENT_SECRET=REPLACE-ME-AZURE-CLIENT-SECRET
MS_REDIRECT_URI=https://mailpilot.deine-domain.de/api/v1/auth/oauth/callback


# ─── Admin UI ────────────────────────────────────────────────────────────
# Login user.
ADMIN_USER=admin

# Password hash. Two ways to provide it:
#
# (B) ADMIN_PASS_HASH_B64  ← RECOMMENDED on DSM
#     base64 of the bcrypt hash. No '$' inside, so docker-compose / DSM
#     can't mis-interpret it as a variable reference.
#     Generate:
#       HASH=$(docker run --rm php:8.4-cli-alpine \
#               php -r 'echo password_hash("YOUR_PASSWORD", PASSWORD_BCRYPT);')
#       echo -n "$HASH" | base64 -w0
#
# (A) ADMIN_PASS_HASH (raw)
#     Works on plain Linux but FAILS on DSM whenever the bcrypt hash
#     contains '$DGQ…' style sequences — docker-compose treats them as env
#     vars and silently truncates the hash. Leave empty unless you know
#     your environment doesn't substitute '$'.
#
# admin/config/admin.php uses _B64 if set; falls back to the raw hash
# otherwise.
ADMIN_PASS_HASH=
ADMIN_PASS_HASH_B64=REPLACE-ME-BASE64-OF-BCRYPT-HASH

# Optional IP allow-list for /admin (CIDR comma-separated, e.g.
# "10.0.0.0/8,192.168.1.0/24"). Disabled by default.
ADMIN_IP_RESTRICT=false
ADMIN_ALLOWED_IPS=
