{
	"name": "s-techsmd/mailpilot-ai-backend",
	"description": "MailPilot AI backend — Claude-powered Outlook email triage",
	"type": "project",
	"license": "proprietary",
	"require": {
		"php": ">=8.4",
		"ext-pdo": "*",
		"ext-json": "*",
		"ext-curl": "*",
		"ext-openssl": "*",
		"firebase/php-jwt": "^6.10",
		"vlucas/phpdotenv": "^5.6",
		"monolog/monolog": "^3.5"
	},
	"require-dev": {
		"phpunit/phpunit": "^11.0",
		"friendsofphp/php-cs-fixer": "^3.50"
	},
	"autoload": {
		"psr-4": {
			"MailPilot\\": "src/"
		}
	},
	"autoload-dev": {
		"psr-4": {
			"MailPilot\\Tests\\": "tests/"
		}
	},
	"scripts": {
		"test": "phpunit",
		"cs-fix": "php-cs-fixer fix --using-cache=no"
	},
	"config": {
		"audit": {
			"ignore": {
				"PKSA-y2cr-5h3j-g3ys": "We use HS256 only — algorithm-confusion advisory does not apply"
			}
		}
	}
}
