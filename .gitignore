# Composer
vendor/
composer.lock

# Local config — secrets must never be committed
backend/config/config.php
admin/config/admin.local.php
docker/.env
docker/.env.*
!docker/.env.example
.env
.env.local
.env.*.local

# Logs / runtime — backend/var/ ist gemischt:
#   - log/, phpstan/ : runtime, ignorieren
#   - psl/           : build-time Resource (Mozilla Public Suffix List),
#                      muss commited werden, wird vom SenderResolver geladen
backend/var/log/
backend/var/phpstan/
backend/var/cache/
*.log

# Editor / IDE / agent
.idea/
.vscode/
.claude/
*.swp
*.swo
.DS_Store
Thumbs.db

# PHPUnit
backend/.phpunit.cache/
backend/.phpunit.result.cache
backend/coverage/

# php-cs-fixer
.php-cs-fixer.cache

# Node (Add-in dev server)
node_modules/

# Build artefacts
*.tar.gz
*.zip
dist/

# Generated Office Add-in manifest (built via addin/build-manifest.sh)
addin/manifest.xml
mailpilot-worker.*

# Workspace dumps from operator (never commit)
/.env
/.env.example
/docker-compose*.yml
